{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ASUS TUF Gaming M3",
  "version": "0.1.0",
  "identifier": "com.asus.mousecontrol",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ASUS TUF Gaming M3",
        "width": 360,
        "height": 600,
        "resizable": false,
        "maximizable": false,
        "visible": false,
        "decorations": false,
        "skipTaskbar": true,
        "alwaysOnTop": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}